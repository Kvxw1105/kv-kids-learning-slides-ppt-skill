    {
      "id": "S03",
      "role": "child-speech",
      "screen": {
        "text_blocks": [
          {
            "id": "S03_stage_en",
            "lang": "en",
            "text": "Small at first\ntwo leaves and one pink bud",
            "font_size_pt": 25,
            "visible_in": [
              "stage",
              "rehearsal"
            ]
          },
          {
            "id": "S03_stage_zh",
            "lang": "zh",
            "text": "一开始很小\n两片叶子和一个粉色花苞",
            "font_size_pt": 21,
            "visible_in": [
              "stage",
              "rehearsal"
            ]
          }
        ]
      },
      "speaker": {
        "script_en": "When I first saw Pinky, she was very small. She had two green leaves and one tiny pink bud, like a little sleeping hat.",
        "script_zh": "我第一次看到小粉的时候，她很小。她有两片绿色的叶子，还有一个小小的粉色花苞，像一顶正在睡觉的小帽子。",
        "actions": [
          "use small hand gesture"
        ]
      },
      "visual": {
