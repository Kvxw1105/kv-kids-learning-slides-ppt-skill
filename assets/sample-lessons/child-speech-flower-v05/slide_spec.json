    {
      "id": "S04",
      "role": "child-speech",
      "screen": {
        "text_blocks": [
          {
            "id": "S04_stage_en",
            "lang": "en",
            "text": "Good morning, Pinky.\nlook, touch, and check",
            "font_size_pt": 25,
            "visible_in": [
              "stage",
              "rehearsal"
            ]
          },
          {
            "id": "S04_stage_zh",
            "lang": "zh",
            "text": "早上好，小粉。\n看一看，摸一摸，检查一下",
            "font_size_pt": 21,
            "visible_in": [
              "stage",
              "rehearsal"
            ]
          }
        ]
      },
      "speaker": {
        "script_en": "Every morning, I say, Good morning, Pinky. I look at her leaves. I check the soil with one gentle finger.",
        "script_zh": "每天早上，我都会说：早上好，小粉。我看看她的叶子，再用一根手指轻轻碰一碰泥土。",
        "actions": [
          "touch one finger gently"
        ]
      },
      "visual": {
        "layout": "card2",
        "style": "premium-paper-theater",
        "story_state": "s04",
        "required_action": "stage cue or story object shown",
        "character_ids": [],
        "completion": {
