    {
      "id": "S05",
      "role": "child-speech",
      "screen": {
        "text_blocks": [
          {
            "id": "S05_stage_en",
            "lang": "en",
            "text": "Water, little by little.\ndrop by drop",
            "font_size_pt": 25,
            "visible_in": [
              "stage",
              "rehearsal"
            ]
          },
          {
            "id": "S05_stage_zh",
            "lang": "zh",
            "text": "一点一点浇水。\n一滴一滴，慢慢来",
            "font_size_pt": 21,
            "visible_in": [
              "stage",
              "rehearsal"
            ]
          }
        ]
      },
      "speaker": {
        "script_en": "Then I give her some water. I do not pour too much. Just a small drink, drop by drop, because plants need care.",
        "script_zh": "然后我给她浇一点水。我不会倒太多。只是一点点，一滴一滴，因为植物需要温柔的照顾。",
        "actions": [
          "pretend to pour water"
        ]
      },
      "visual": {
