              "stage",
              "rehearsal"
            ]
          },
          {
            "id": "S09_stage_zh",
            "lang": "zh",
            "text": "我很骄傲。\n我每天都照顾她。",
            "font_size_pt": 21,
            "visible_in": [
              "stage",
              "rehearsal"
            ]
          }
        ]
      },
      "speaker": {
        "script_en": "I clapped my hands and smiled. I felt proud because I helped Pinky every day. Pinky made my heart feel warm.",
        "script_zh": "我拍了拍手，也笑了。我觉得很骄傲，因为我每天都在照顾小粉。小粉让我的心里暖暖的。",
